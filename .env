DEBUG = 0

# *_BORDER_WIDTH is the width INCLUDING the border.
STROKE_BORDER_WIDTH   = 4.5
STROKE_BORDER_COLOR   = "#666"
STROKE_UNFILLED_COLOR = "#eee"
STROKE_UNFILLED_WIDTH = 3
STROKE_FILLING_COLOR  = "#f00"
STROKE_FILLED_COLOR   = "#000"
STROKE_FILLED_WIDTH   = 3.1

# brush settings
SHOW_BRUSH              = 1
SHOW_BRUSH_FRONT_BORDER = 1
BRUSH_COLOR             = "#f00"
BRUSH_WIDTH             = 5.5
BRUSH_BORDER_COLOR      = "#666"
BRUSH_BORDER_WIDTH      = 7

SHOW_STROKE_NUMBERS = 1
STROKE_NUMBERS_COLOR = "#888"
STROKE_NUMBERS_FONT = "sans-serif"

WAIT_AFTER = 1.5

# gif settings
DELETE_TEMPORARY_FILES = 1
GIF_SIZE               = 150
GIF_FRAME_DURATION     = 0.04
GIF_BACKGROUND_COLOR   = '#ddf'
# set to true to allow transparent background, much bigger file!
GIF_ALLOW_TRANSPARENT  = 0

# edit here to decide what will be generated
GENERATE_SVG           = 1
GENERATE_JS_SVG        = 1
GENERATE_GIF           = 1

# sqrt, ie a stroke 4 times the length is drawn
# at twice the speed, in twice the time.
STROKE_LENGTH_TO_DURATION = "length ** 0.5 / 8"

# global time rescale, let's make animation a bit
# faster when there are many strokes.
TIME_RESCALE = "(2 * interval) ** (2.0 / 3)"

# Possibilities are linear, ease, ease-in, ease-in-out, ease-out, see
#   https://developer.mozilla.org/en-US/docs/Web/CSS/timing-function
# for more info.
TIMING_FUNCTION = "ease-in-out"

#
# colorful debug settings
#
#STROKE_BORDER_COLOR   = "#00f"
#STROKE_UNFILLED_COLOR = "#ff0"
#STROKE_FILLING_COLOR  = "#f00"
#STROKE_FILLED_COLOR   = "#000"

